# ========================================================
# לוזניק — משתני סביבה
# ========================================================
# העתק קובץ זה ל-.env.local ומלא את הערכים
# אל תעלה .env.local ל-git (הוא ב-.gitignore)
#
# כיצד לייצר HASH לסיסמה:
#   פתח את הדפדפן, כנס ל-Console (F12) והדבק:
#
#   const hash = async (s) => [...new Uint8Array(
#     await crypto.subtle.digest('SHA-256', new TextEncoder().encode(s))
#   )].map(b=>b.toString(16).padStart(2,'0')).join('');
#   hash('הסיסמה-שלך').then(console.log);
#
#   העתק את הפלט לשורה המתאימה למטה.
#
# לאחר מכן ב-Firebase Hosting:
#   Firebase Console → Project Settings → Environment configuration
# ========================================================

# סיסמת מנהל (גישה מלאה: יצירה, עריכה, מחיקה, ניהול הגדרות)
VITE_ADMIN_PASSWORD_HASH=הכנס-כאן-את-ה-SHA256-של-סיסמת-המנהל

# סיסמת צוות (גישת מורים: צפייה באירועי צוות ואירועים ציבוריים)
VITE_TEACHER_PASSWORD_HASH=הכנס-כאן-את-ה-SHA256-של-סיסמת-הצוות

# ── Firebase ──────────────────────────────────────────────────────────────────
# Firebase Console → Project Settings → Your apps → Web app config
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ── OneSignal (התראות שבועיות) ──────────────────────────────────────────────────
# OneSignal Dashboard → Settings → Keys & IDs
VITE_ONESIGNAL_APP_ID=REPLACE_WITH_YOUR_APP_ID
# REST API Key — לשימוש הסקריפט בלבד (scripts/sendWeeklyPush.mjs) ו-GitHub Secret
ONESIGNAL_REST_API_KEY=REPLACE_WITH_YOUR_KEY
